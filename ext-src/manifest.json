{
  "manifest_version": 3,
  "name": "No Distraction Guard",
  "version": "1.0.0",
  "description": "Blocks feed pages (YouTube home/Shorts, Facebook home) even during in-app SPA navigation. Deployed by enterprise policy.",
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.facebook.com/*"],
      "js": ["cs.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["*://*.youtube.com/*", "*://*.facebook.com/*"]
    }
  ]
}
